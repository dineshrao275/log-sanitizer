{
    "name": "dineshrao275/log-sanitizer",
    "description": "A lightweight Monolog processor to automatically redact PII and sensitive data from logs.",
    "type": "library",
    "license": "MIT",
    "keywords": ["monolog", "logging", "pii", "gdpr", "redact", "sanitize"],
    "autoload": {
        "psr-4": {
            "Dineshrao275\\LogSanitizer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dineshrao275\\L    ogSanitizer\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Dinesh Rao",
            "email": "dineshrao275@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "minimum-stability": "stable"
}